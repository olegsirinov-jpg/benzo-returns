Options -Indexes -ExecCGI
AddType text/plain .php .php3 .phtml .pht .phar

# php_flag працює лише під mod_php — під FPM/CGI викликав би 500,
# тому основний захист нижче через FilesMatch.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

<FilesMatch "\.(php|php3|phtml|pht|phar|cgi|pl|py|sh|html?)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
