# Скопіюйте цей файл у .env і заповніть значення.
# .env НЕ має потрапляти в git і не має бути доступним з вебу.

APP_ENV=local
APP_DEBUG=1
APP_URL=http://povirnenya
APP_NAME="Обмін та повернення"

# База даних
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=povirnenya
DB_USER=root
DB_PASS=

# SalesDrive
# Ключ: Установки -> Загальні налаштування і інтеграції -> Інші сервіси -> API -> API-ключі
SD_ENABLED=1
SD_URL=https://yourdomain.salesdrive.me
SD_API_KEY=
# Ключ бази заявок (потрібен для api/order/update/)
SD_FORM_KEY=
# Скільки днів назад шукати замовлення
SD_SEARCH_DAYS=120

# Telegram
TG_ENABLED=0
TG_BOT_TOKEN=
TG_CHAT_ID=

# Секрет для крон-скриптів: /cron/stale.php?key=...
CRON_KEY=change-me-to-random-string

# Термін повернення, днів
RETURN_DAYS=14
